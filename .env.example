# ---------------------------------------------------------------------------
# Supabase (cliente) — fonte de verdade dos dados.
# A anon key É PÚBLICA por design (vai no bundle do cliente); o que protege os
# dados é o Row Level Security (RLS). Copia para `.env` e preenche.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="SUA_ANON_KEY"

# ---------------------------------------------------------------------------
# Supabase Service Role (SECRETA) — só no servidor, NUNCA no cliente.
# Supabase Dashboard → Settings → API → service_role key. Usada para criar
# utilizadores convidados (registo fechado).
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY"

# ---------------------------------------------------------------------------
# Gemini (servidor) — usado pelo endpoint /api/gemini/chat.
# ---------------------------------------------------------------------------
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
